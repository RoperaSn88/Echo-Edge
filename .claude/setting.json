{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./Library/**)",
      "Read(./obj/**)",

      "Glob(./Library/**)",
      "Glob(./obj/**)",

      "Grep(./Library/**)",
      "Grep(./obj/**)",

      "Bash(ls Library*)",
      "Bash(ls obj*)",

      "Bash(find Library*)",
      "Bash(find obj*)",
  
      "Bash(cat Library/*)",
      "Bash(cat obj/*)",
    ]
  }
}