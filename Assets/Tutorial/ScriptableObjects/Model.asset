    - _text: "\u300E\u4E00\u9583\u300F\u306F\u547D\u4E2D\u3057\u305F\u6575\u3078\u30C0\u30E1\u30FC\u30B8\u3092\u4E0E\u3048\u308B\u3002\n\u9023\u7D9A\u3057\u3066\u547D\u4E2D\u3055\u305B\u308C\u3070\u3001\u4E0E\u3048\u308B\u30C0\u30E1\u30FC\u30B8\u306F\u5897\u52A0\u3059\u308B\u3002\n\u53CD\u5C04\u56DE\u6570\u306B\u306F\u9650\u5EA6\u304C\u3042\u308B\u3002\u8ECC\u9053\u306F\u3088\u304F\u898B\u3066\u304A\u3051\u3002"
